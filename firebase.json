{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app.html",
        "destination": "/app.html"
      },
      {
        "source": "/admin-app.html",
        "destination": "/admin-app.html"
      },
      {
        "source": "/admin-login.html",
        "destination": "/admin-login.html"
      },
      {
        "source": "**",
        "destination": "/login.html"
      }
    ]
  }
}